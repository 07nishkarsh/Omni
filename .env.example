# Gemini API Key Pool (comma-separated; 1 key also works)
# Keys are rotated automatically on 429 rate-limit errors.
# Key values are NEVER written to logs or the Notion Audit Feed.
GEMINI_API_KEYS=key_one,key_two,key_three

# Legacy single-key fallback (used if GEMINI_API_KEYS is not set)
LLM_API_KEY=your_llm_api_key_here

LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Max LLM calls per minute (client-side token bucket, per process)
LLM_CALLS_PER_MINUTE=10

# Notion MCP (use placeholders; keep secrets out of git)
NOTION_TOKEN=mock-notion-token
NOTION_PARENT_PAGE_ID=mock-parent-page-id

NOTION_POLICY_BOOK_ID=mock-policy-book-id
NOTION_APPROVAL_DESK_ID=mock-approval-desk-id
NOTION_TREASURY_LEDGER_ID=mock-treasury-ledger-id
NOTION_AUDIT_FEED_ID=mock-audit-feed-id

# Gmail OAuth (placeholders)
GMAIL_CLIENT_ID=mock-gmail-client-id
GMAIL_CLIENT_SECRET=mock-gmail-client-secret
GMAIL_REFRESH_TOKEN=mock-gmail-refresh-token
GMAIL_SENDER_ADDRESS=no-reply@mockbank.example.com

# Slack (placeholders)
SLACK_WEBHOOK_URL=https://hooks.slack.com/mock/webhook
SLACK_BOT_TOKEN=xoxb-mock-token
SLACK_CHANNEL_ID=C00000000

APP_ENV=development
APP_SECRET_KEY=change_me_to_a_secure_random_string
LOG_LEVEL=INFO

USE_MOCK_NOTION=true
USE_MOCK_GMAIL=true
USE_MOCK_SLACK=true
USE_MOCK_LLM=true
